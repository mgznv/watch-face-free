    <path android:fillColor="#00000000" android:strokeColor="#FFFFFF" android:strokeWidth="1.5"
        android:pathData="M100,100 m-90,0 a90,90 0 1,0 180,0 a90,90 0 1,0 -180,0" />
    <!-- Single weight hands (same stroke width) -->
    <path android:strokeColor="#FFFFFF" android:strokeWidth="1.5" android:strokeLineCap="round"
        android:pathData="M100,100 L118,60" />
    <path android:strokeColor="#FFFFFF" android:strokeWidth="1.5" android:strokeLineCap="round"
        android:pathData="M100,100 L100,26" />
    <path android:strokeColor="#FFFFFF" android:strokeWidth="1.5" android:strokeLineCap="round"
        android:pathData="M100,108 L100,22" />
    <!-- Single weight tick marks -->
    <path android:strokeColor="#FFFFFF" android:strokeWidth="1.5"
        android:pathData="M100,12 L100,20 M188,100 L180,100 M100,188 L100,180 M12,100 L20,100" />
    <path android:fillColor="#00000000" android:strokeColor="#FFFFFF" android:strokeWidth="1.5"
        android:pathData="M100,100 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" />

<?xml version="1.0" encoding="utf-8"?>
<!-- Preview: Monoline – single weight line art style -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp" android:height="200dp"
    android:viewportWidth="200" android:viewportHeight="200">
    <path android:fillColor="#0E0E0E" android:pathData="M100,100 m-100,0 a100,100 0 1,0 200,0 a100,100 0 1,0 -200,0" />

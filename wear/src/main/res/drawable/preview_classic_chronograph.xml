<?xml version="1.0" encoding="utf-8"?>
<!-- Preview: Classic Chronograph – dark dial, silver hands, sub-dials -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    <!-- Background -->
    <path android:fillColor="#1A1A1A" android:pathData="M100,100 m-100,0 a100,100 0 1,0 200,0 a100,100 0 1,0 -200,0" />
    <!-- Outer ring -->
    <path android:fillColor="#00000000" android:strokeColor="#888888" android:strokeWidth="3"
        android:pathData="M100,100 m-94,0 a94,94 0 1,0 188,0 a94,94 0 1,0 -188,0" />
    <!-- Hour markers -->
    <path android:strokeColor="#CCCCCC" android:strokeWidth="3"
        android:pathData="M100,10 L100,22 M100,178 L100,190 M10,100 L22,100 M178,100 L190,100" />
    <!-- Sub-dial top -->
    <path android:fillColor="#2A2A2A" android:pathData="M100,50 m-14,0 a14,14 0 1,0 28,0 a14,14 0 1,0 -28,0" />
    <!-- Hour hand -->
    <path android:strokeColor="#FFFFFF" android:strokeWidth="4" android:strokeLineCap="round"
        android:pathData="M100,100 L115,62" />
    <!-- Minute hand -->
    <path android:strokeColor="#DDDDDD" android:strokeWidth="2.5" android:strokeLineCap="round"
        android:pathData="M100,100 L100,28" />
    <!-- Second hand -->
    <path android:strokeColor="#FF4444" android:strokeWidth="1.5" android:strokeLineCap="round"
        android:pathData="M100,115 L100,22" />
    <!-- Center cap -->
    <path android:fillColor="#CCCCCC" android:pathData="M100,100 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" />
</vector>
